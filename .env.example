# ── REQUIRED: eBay Browse API (free) ─────────────────────────────
# Get these at https://developer.ebay.com → Your Account → Application Keys
# Use the PRODUCTION keyset (App ID = Client ID, Cert ID = Client Secret)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_US
# The Browse quota for the WHOLE deployment (all users share it). 5000 is
# eBay's default; only raise this if eBay has actually granted you more.
EBAY_DAILY_QUOTA=5000

# ── REQUIRED: Supabase (auth + tenants + the budget ledger) ───────
# Create a project, run supabase-schema.sql in the SQL editor, then copy from
# Project Settings → API. The VITE_ vars are bundled into the client AND read
# by the functions — one name, one project, no drift.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# The account that gets the deployment console (and claims any pre-multi-tenant
# watches/deals rows on first login).
ADMIN_EMAIL=

# ── OPTIONAL: Stripe billing ──────────────────────────────────────
# Without these the app runs fine — everyone stays on Scout and the Settings
# page says billing isn't configured. To sell plans: create two recurring
# Prices in Stripe (Picker, Operator), paste their price_… ids, and point a
# webhook at /api/stripe-webhook with events: checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PICKER=
STRIPE_PRICE_OPERATOR=
# Override the checkout return URL if the Netlify URL isn't your real domain.
# APP_URL=https://blindspot.example.com

# ── OPTIONAL: automated sold comps ────────────────────────────────
# eBay gates official sold data behind partner-only APIs. This app can proxy
# a third-party sold-listings API instead (Picker+ feature; the shared cache
# serves everyone). Subscribe at:
# https://rapidapi.com/ecommet/api/ebay-average-selling-price
RAPIDAPI_KEY=

# ── OPTIONAL: deployment-fallback Discord webhook ─────────────────
# Users set their own webhook in Settings. This one only catches watches whose
# owner hasn't set one (i.e., your original solo setup keeps working).
DISCORD_WEBHOOK_URL=

# ── Default seller economics ──────────────────────────────────────
# Per-user values live in Settings now. These env vars are gone on purpose:
# FEE_RATE / PER_ORDER_FEE were deployment-wide, which is wrong once there's
# more than one seller. Defaults ship in src/lib/scoring.js (13.35% + $0.40).
