# ── REQUIRED: eBay Browse API (free) ─────────────────────────────
# Get these at https://developer.ebay.com → Your Account → Application Keys
# Use the PRODUCTION keyset (App ID = Client ID, Cert ID = Client Secret)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_US

# ── OPTIONAL: automated sold comps ────────────────────────────────
# eBay gates official sold data behind partner-only APIs. This app can proxy
# a third-party sold-listings API instead. Subscribe at:
# https://rapidapi.com/ecommet/api/ebay-average-selling-price
# Leave blank to use manual comp mode (paste median from the sold-listings URL
# the app gives you, or from Terapeak in Seller Hub — free with your eBay account).
RAPIDAPI_KEY=

# ── OPTIONAL: persistence + scheduled watches ─────────────────────
# Run supabase-schema.sql in your Supabase project first.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── OPTIONAL: Discord alerts from the scheduled watcher ───────────
DISCORD_WEBHOOK_URL=

# ── Economics (tune to your seller account) ───────────────────────
# eBay final value fee varies by category/store level. 13.35% + $0.40/order
# is a sane default for most tech categories — verify yours in Seller Hub.
FEE_RATE=0.1335
PER_ORDER_FEE=0.40
